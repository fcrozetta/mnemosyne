CREATE PROPERTY Entity.resolution_status IF NOT EXISTS STRING;
CREATE PROPERTY Entity.scope IF NOT EXISTS STRING;
CREATE PROPERTY Entity.sensitivity IF NOT EXISTS STRING;
CREATE PROPERTY Entity.allowed_purposes IF NOT EXISTS STRING;
CREATE PROPERTY Entity.created_at IF NOT EXISTS DATETIME;
CREATE PROPERTY Entity.updated_at IF NOT EXISTS DATETIME;

CREATE PROPERTY Person.display_name IF NOT EXISTS STRING;
CREATE PROPERTY Person.given_name IF NOT EXISTS STRING;
