CREATE PROPERTY Store.installment_summary IF NOT EXISTS STRING;
CREATE PROPERTY Store.payment_methods_summary IF NOT EXISTS STRING;
CREATE PROPERTY Store.source_urls IF NOT EXISTS STRING;
CREATE PROPERTY Store.reference_notes IF NOT EXISTS STRING;
CREATE PROPERTY Store.verified_at IF NOT EXISTS DATETIME;

CREATE PROPERTY Item.item_kind IF NOT EXISTS STRING;
CREATE PROPERTY Item.category IF NOT EXISTS STRING;
CREATE PROPERTY Item.subcategory IF NOT EXISTS STRING;
CREATE PROPERTY Item.brand IF NOT EXISTS STRING;
CREATE PROPERTY Item.model IF NOT EXISTS STRING;
