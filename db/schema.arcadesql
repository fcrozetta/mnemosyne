CREATE PROPERTY Item.size IF NOT EXISTS STRING;
CREATE PROPERTY Item.serial_number IF NOT EXISTS STRING;
CREATE PROPERTY Item.identifiers IF NOT EXISTS STRING;

CREATE PROPERTY PaymentMethod.provider_category IF NOT EXISTS STRING;
CREATE PROPERTY PaymentMethod.website IF NOT EXISTS STRING;
CREATE PROPERTY PaymentMethod.reference_notes IF NOT EXISTS STRING;

