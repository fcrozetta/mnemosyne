CREATE PROPERTY Location.country IF NOT EXISTS STRING;
CREATE PROPERTY Location.latitude IF NOT EXISTS DOUBLE;
CREATE PROPERTY Location.longitude IF NOT EXISTS DOUBLE;
CREATE PROPERTY Location.source_url IF NOT EXISTS STRING;
CREATE PROPERTY Location.reference_notes IF NOT EXISTS STRING;

CREATE PROPERTY Claim.id IF NOT EXISTS STRING;
CREATE PROPERTY Claim.statement IF NOT EXISTS STRING;
CREATE PROPERTY Claim.status IF NOT EXISTS STRING;
